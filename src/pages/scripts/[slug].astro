---
import ScriptLayout from '../../layouts/ScriptLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const scripts = await getCollection('scripts');
  return scripts.map((script) => ({
    params: { slug: script.slug },
    props: { script },
  }));
}

const { script } = Astro.props;
const { Content } = await script.render();
const { title, description, date, total_word_count, spoken_word_count, type, tags, pdf } = script.data;
---

<ScriptLayout
  title={title}
  description={description}
  date={date}
  total_word_count={total_word_count}
  spoken_word_count={spoken_word_count}
  type={type}
  tags={tags}
  pdf={pdf}
>
  <Content />
</ScriptLayout>
