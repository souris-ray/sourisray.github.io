# ============================================
# Astro + Node — Build Outputs & Caches
# ============================================

# Astro build output (GitHub Actions builds this fresh each deploy)
dist/

# Astro internal cache & type generation
.astro/

# Node dependencies (installed fresh in CI via npm ci)
node_modules/


# ============================================
# Development Environment
# ============================================

# Environment / secrets — never commit these
.env
.env.local
.env.production
.env.*.local


# ============================================
# Log Files
# ============================================

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log


# ============================================
# OS & Editor Noise
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo


# ============================================
# Jekyll (Legacy — Safe to Delete These Too)
# ============================================

_site/
.jekyll-cache/
.jekyll-metadata
Gemfile
Gemfile.lock
_config.yml


# ============================================
# Project-Specific Private Files
# ============================================

# Source assets folder (content already copied to public/assets/)
/assets/

# Private tracking / admin files
*.xlsx
*.xls


# ============================================
# Misc
# ============================================

# Temporary files
*.tmp
*.temp